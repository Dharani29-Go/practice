{% comment %}
================================================================================
  TISSO VISON — Banner Section
  File   : sections/tisso-banner.liquid
  Purpose: Full-width hero banner with:
             • Top navigation bar (logo, tagline, CTA button)
             • Background illustration image
             • Editable heading, subtext, and "Shop Now" CTA
             • Bottom ticker text
  All text fields are editable from the Shopify Theme Customizer.
  No jQuery — vanilla JS only (no JS needed for this section).
================================================================================
{% endcomment %}

<section
  class="tv-banner"
  id="tv-banner-{{ section.id }}"
  aria-label="Hero Banner"
>

  {%- comment %} ── 1. TOP NAVIGATION BAR ── {% endcomment %}
  <nav class="tv-banner__nav" role="navigation" aria-label="Site navigation">

    <span class="tv-banner__logo">
      {{ section.settings.logo_text }}
    </span>

    <span class="tv-banner__nav-tagline">
      {{ section.settings.nav_tagline }}
    </span>

    <a
      href="{{ section.settings.choose_gift_url }}"
      class="tv-btn tv-btn--yellow"
      aria-label="{{ section.settings.choose_gift_label }}"
    >
      {{ section.settings.choose_gift_label }}
      <span class="tv-btn__arrow" aria-hidden="true">&#8594;</span>
    </a>

  </nav>

  {%- comment %} ── 2. HERO AREA ── {% endcomment %}
  <div class="tv-banner__hero">

    {%- comment %} Background illustration image (right side) {% endcomment %}
    {%- if section.settings.background_image != blank %}
      <div class="tv-banner__bg" aria-hidden="true">
        {{
          section.settings.background_image
          | image_url: width: 1600
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            alt: '',
            class: 'tv-banner__bg-img'
        }}
      </div>
    {%- endif %}

    {%- comment %} Text content — overlays bottom-left of hero {% endcomment %}
    <div class="tv-banner__content">
      <h1 class="tv-banner__heading">{{ section.settings.heading }}</h1>
      <p  class="tv-banner__description">{{ section.settings.description }}</p>
      <a
        href="{{ section.settings.shop_now_url }}"
        class="tv-btn tv-btn--black"
        aria-label="{{ section.settings.shop_now_label }}"
      >
        {{ section.settings.shop_now_label }}
        <span class="tv-btn__arrow" aria-hidden="true">&#8594;</span>
      </a>
    </div>

  </div>

  {%- comment %} ── 3. BOTTOM TICKER BAR ── {% endcomment %}
  <div class="tv-banner__ticker" aria-label="Store message">
    <p>{{ section.settings.ticker_text }}</p>
  </div>

</section>


{%- comment %} ════════════════ STYLES ════════════════ {% endcomment %}
<style>
  /* ─── CSS custom properties (scoped to this section) ─── */
  #tv-banner-{{ section.id }} {
    --tv-font-serif  : 'Georgia', 'Times New Roman', serif;
    --tv-font-sans   : 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --tv-black       : #000000;
    --tv-white       : #ffffff;
    --tv-yellow      : #f5e63e;
    --tv-yellow-hover: #e0d100;
    --tv-gray-bg     : #f2f2f2;
    --tv-border      : #e2e2e2;
    --tv-speed       : 0.28s;
  }

  /* ─── Section wrapper ─── */
  .tv-banner {
    font-family : var(--tv-font-sans);
    background  : var(--tv-white);
    border-bottom: 1px solid var(--tv-border);
  }

  /* ─── Navigation bar ─── */
  .tv-banner__nav {
    display         : flex;
    align-items     : center;
    justify-content : space-between;
    padding         : 14px 40px;
    border-bottom   : 1px solid var(--tv-border);
    background      : var(--tv-white);
    position        : relative;
    z-index         : 10;
  }

  .tv-banner__logo {
    font-weight    : 700;
    font-size      : 1.05rem;
    letter-spacing : 0.06em;
    text-transform : uppercase;
    color          : var(--tv-black);
  }

  .tv-banner__nav-tagline {
    font-size : 0.88rem;
    color     : #444;
  }

  /* ─── Button base ─── */
  .tv-btn {
    display       : inline-flex;
    align-items   : center;
    gap           : 10px;
    padding       : 11px 20px;
    font-family   : var(--tv-font-sans);
    font-size     : 0.8rem;
    font-weight   : 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border        : none;
    cursor        : pointer;
    transition    : background-color var(--tv-speed) ease,
                    color var(--tv-speed) ease;
  }

  /* Arrow slide animation */
  .tv-btn__arrow {
    display   : inline-block;
    transition: transform var(--tv-speed) ease;
  }
  .tv-btn:hover .tv-btn__arrow {
    transform: translateX(5px);
  }

  /* Yellow variant (nav CTA) */
  .tv-btn--yellow {
    background-color: var(--tv-yellow);
    color           : var(--tv-black);
  }
  .tv-btn--yellow:hover {
    background-color: var(--tv-yellow-hover);
  }

  /* Black variant (hero CTA) */
  .tv-btn--black {
    background-color: var(--tv-black);
    color           : var(--tv-white);
  }
  .tv-btn--black:hover {
    background-color: #222;
  }

  /* ─── Hero area ─── */
  .tv-banner__hero {
    position  : relative;
    min-height: 480px;
    overflow  : hidden;
    display   : flex;
    align-items: flex-end; /* text anchors to bottom-left */
    background: var(--tv-white);
  }

  /* Background illustration fills the right/full area */
  .tv-banner__bg {
    position: absolute;
    inset   : 0;
    z-index : 0;
  }
  .tv-banner__bg-img {
    width        : 100%;
    height       : 100%;
    object-fit   : cover;
    object-position: right center;
    display      : block;
  }

  /* Text content — left side, above the illustration */
  .tv-banner__content {
    position      : relative;
    z-index       : 2;
    padding       : 40px 40px 50px;
    max-width     : 440px;
    display       : flex;
    flex-direction: column;
    gap           : 18px;
  }

  .tv-banner__heading {
    font-family: var(--tv-font-serif);
    font-size  : clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    line-height: 1.1;
    margin     : 0;
    color      : var(--tv-black);
  }

  .tv-banner__description {
    font-size  : 0.92rem;
    line-height: 1.65;
    color      : #222;
    margin     : 0;
  }

  /* ─── Ticker bar ─── */
  .tv-banner__ticker {
    background  : var(--tv-gray-bg);
    padding     : 10px 40px;
    text-align  : center;
    border-top  : 1px solid var(--tv-border);
  }
  .tv-banner__ticker p {
    margin        : 0;
    font-size     : 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color         : #333;
  }

  /* ─── Mobile (≤ 768px) ─── */
  @media (max-width: 768px) {
    .tv-banner__nav {
      padding: 12px 20px;
    }
    /* Hide tagline on small screens to avoid crowding */
    .tv-banner__nav-tagline {
      display: none;
    }
    .tv-banner__hero {
      min-height: 360px;
    }
    .tv-banner__content {
      padding  : 24px 20px 36px;
      max-width: 100%;
    }
    .tv-banner__heading {
      font-size: 2rem;
    }
    .tv-btn--yellow {
      font-size: 0.72rem;
      padding  : 9px 14px;
    }
    .tv-banner__ticker {
      padding: 10px 20px;
    }
  }
</style>


{%- comment %} ════════════════ SCHEMA ════════════════ {% endcomment %}
{% schema %}
{
  "name": "Tisso Banner",
  "tag": "section",
  "class": "tisso-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Navigation Bar"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "nav_tagline",
      "label": "Navigation Tagline",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "choose_gift_label",
      "label": "\"Choose Gift\" Button Label",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "choose_gift_url",
      "label": "\"Choose Gift\" Button URL"
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Illustration Image",
      "info": "Upload the line-art gift guide illustration. Recommended width: 1600px."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "shop_now_label",
      "label": "\"Shop Now\" Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "shop_now_url",
      "label": "\"Shop Now\" Button URL"
    },
    {
      "type": "header",
      "content": "Ticker Bar"
    },
    {
      "type": "text",
      "id": "ticker_text",
      "label": "Ticker Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    }
  ],
  "presets": [
    {
      "name": "Tisso Banner"
    }
  ]
}
{% endschema %}
